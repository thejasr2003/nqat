generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  phone        String
  altPhone     String?
  usn          String       @unique
  collegeName  String
  passoutBatch String
  branch       String
  sem          Int
  cgpa         Float
  submissions  Submission[]
  createdAt    DateTime     @default(now())
}

model Test {
  id                 String              @id // Can be any string, e.g., "main-test"
  title              String
  questions          Question[]
  numericQuestions   NumericQuestion[]
  wordBlankQuestions WordBlankQuestion[]
  longAnswerQuestions LongAnswerQuestion[]
  submissions        Submission[]
}

model Question {
  id       String @id @default(uuid())
  testId   String
  question String
  option1  String
  option2  String
  option3  String
  option4  String
  answer   String
  test     Test   @relation(fields: [testId], references: [id])

  @@index([testId])
}

model NumericQuestion {
  id            String   @id @default(cuid())
  testId        String
  questionText  String
  correctAnswer Float
  marks         Int      @default(2)
  createdAt     DateTime @default(now())
  test          Test     @relation(fields: [testId], references: [id])

  @@index([testId])
}

model WordBlankQuestion {
  id             String   @id @default(cuid())
  testId         String
  paragraph      String
  correctAnswers Json
  marks          Int      @default(2)
  createdAt      DateTime @default(now())
  test           Test     @relation(fields: [testId], references: [id])

  @@index([testId])
}

model LongAnswerQuestion {
  id           String   @id @default(cuid())
  testId       String
  questionText String
  marks        Int      @default(2)
  createdAt    DateTime @default(now())
  test         Test     @relation(fields: [testId], references: [id])
  longAnswers  LongAnswerAnswer[]

  @@index([testId])
}

model LongAnswerAnswer {
  id           String    @id @default(cuid())
  submissionId String
  questionId   String
  candidateId  String?
  answerText   String
  isCorrect    Boolean?
  awardedMarks Int      @default(0)
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  submission   Submission        @relation(fields: [submissionId], references: [id])
  question     LongAnswerQuestion @relation(fields: [questionId], references: [id])

  @@index([submissionId])
  @@index([questionId])
}

model Submission {
  id             String    @id @default(uuid())
  testId         String
  candidateId    String
  answers        Json
  score          Int
  objectiveScore Int      @default(0)
  submittedAt    DateTime  @default(now())
  candidate      Candidate @relation(fields: [candidateId], references: [id])
  test           Test      @relation(fields: [testId], references: [id])
  longAnswers    LongAnswerAnswer[]

  @@unique([testId, candidateId])
  @@index([candidateId])
}
